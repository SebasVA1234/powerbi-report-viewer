# Puerto del servidor
PORT=3000

# Modo (development o production)
NODE_ENV=development

# JWT Secret — OBLIGATORIO. El servidor NO arranca si:
#   - falta,
#   - es el valor de ejemplo, o
#   - tiene menos de 32 caracteres.
# Generar uno seguro con:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=tu_secreto_super_seguro_aqui

# Tiempo de expiración del token
JWT_EXPIRES_IN=8h

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
# Intentos de verificación 2FA (TOTP) por CUENTA antes de bloquear 15 min.
RATE_LIMIT_TOTP_MAX=8

# ============================================================
# SEEDS (sólo aplican a una base de datos NUEVA / primer arranque)
# ============================================================
# Password del usuario 'admin' sembrado en una DB nueva. Si no se setea, cae a
# 'admin123' CON cambio obligatorio en el primer login. En producción es
# OBLIGATORIO setearlo a un valor secreto en el PRIMER deploy, para que la DB
# nueva no nazca con una pass pública (cierra la ventana entre el primer
# arranque y el primer login del admin).
# SEED_ADMIN_PASSWORD=
# Nota: el usuario de prueba 'usuario1' NO se siembra cuando NODE_ENV=production
# (y si quedó de un seed viejo, se desactiva automáticamente).

# CORS - orígenes permitidos (separados por coma)
# En producción setear la(s) URL(s) reales, p.ej.:
#   ALLOWED_ORIGINS=https://powerbi-report-viewer-production.up.railway.app
# "*" funciona pero es inseguro y emite warning en startup.
ALLOWED_ORIGINS=*

# ============================================================
# BASE DE DATOS
# ============================================================
# Driver activo: sqlite | postgres
#  - sqlite   (default): mantiene el comportamiento actual del Portal.
#  - postgres: requiere DATABASE_URL (Railway PG add-on).
DB_DRIVER=sqlite

# Path del archivo SQLite (solo si DB_DRIVER=sqlite)
DB_PATH=./database/powerbi_reports.db

# Connection string de PostgreSQL (solo si DB_DRIVER=postgres)
# Railway lo inyecta automáticamente como DATABASE_URL si añades el add-on PG.
# DATABASE_URL=postgres://usuario:password@host:5432/dbname
